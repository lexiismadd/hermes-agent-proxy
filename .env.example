# Hermes Relay configuration
# Copy this to .env and fill in your values

# Remote Hermes API Server URL
HERMES_REMOTE_URL=http://172.16.1.231:8642

# API Server key (from remote ~/.hermes/.env: API_SERVER_KEY)
HERMES_REMOTE_KEY=

# Profile to route to (lexi, lana, zaylie, family) or empty for default
HERMES_PROFILE=lexi

# ACP service port (internal — VS Code connects via stdio, this is unused)
# Reserved for future TCP transport support
# ACP_PORT=

# MCP service port (internal — VS Code connects via stdio, this is unused)
# Reserved for future TCP transport support
# MCP_PORT=
